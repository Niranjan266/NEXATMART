@model IEnumerable<OnlineGroceryShop.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="container pt-5">
    <div class="row align-items-end mb-5 animate-up">
        <div class="col-md-7">
            <h1 class="display-4 fw-bold" style="color: var(--f-text);">Categories.</h1>
            <p class="text-muted h5 fw-normal mt-2">Organize your store for easy discovery.</p>
        </div>
        <div class="col-md-5 text-md-end mt-4 mt-md-0">
            <div class="d-inline-flex gap-2 p-2 bg-light rounded-pill border" style="border-color: var(--f-border) !important;">
                <a asp-action="Index" class="gh-btn gh-btn-outline py-2 px-4 border-0" style="color: var(--f-text) !important;">Products</a>
                <a asp-action="Categories" class="gh-btn gh-btn-primary py-2 px-4 shadow-sm">Categories</a>
                <a asp-action="SalesReport" class="gh-btn gh-btn-outline py-2 px-4 border-0" style="color: var(--f-text) !important;">Sales</a>
                <a asp-action="Orders" class="gh-btn gh-btn-outline py-2 px-4 border-0" style="color: var(--f-text) !important;">Orders</a>
            </div>
        </div>
    </div>
    <div class="d-flex justify-content-end mb-3">
        <a asp-action="AddCategory" class="gh-btn gh-btn-primary py-2 px-4 shadow-sm fw-bold">+ Add New Category</a>
    </div>

    <div class="f-card p-4 shadow-sm animate-up" style="background: white; animation-delay: 0.1s;">
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0">
                <thead>
                    <tr class="text-muted small border-bottom" style="border-color: var(--f-border) !important;">
                        <th class="pb-3 px-3">Name</th>
                        <th class="pb-3">Description</th>
                        <th class="pb-3 text-end px-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in Model)
                    {
                        <tr class="border-bottom" style="border-color: var(--f-border) !important;">
                            <td class="py-4 px-3 fw-bold h5 mb-0" style="color: var(--f-purple);">@cat.Name</td>
                            <td class="text-muted py-4 small">@cat.Description</td>
                            <td class="text-end px-3">
                                <a asp-action="DeleteCategory" asp-route-id="@cat.Id" class="text-danger text-decoration-none fw-bold small" onclick="return confirm('Remove this category?')">DELETE</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
