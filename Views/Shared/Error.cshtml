@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center pt-5">
    <div class="col-md-8 text-center animate__animated animate__shakeX">
        <div class="card shadow-lg p-5 border-danger">
            <h1 class="text-danger fw-bold mb-4">Oops! Something went wrong.</h1>
            <p class="text-white-50">An error occurred while processing your request. Please try again later or contact the admin.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2 rounded-pill mt-3">Go back Home</a>
        </div>
    </div>
</div>
