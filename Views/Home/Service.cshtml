@{
    ViewData["Title"] = "Our Services";
}

<div class="container py-5">
    <div class="text-center mb-5 animate-up">
        <h1 class="display-4 fw-bold" style="color: var(--f-text);">Premium <span class="text-purple">Services.</span></h1>
        <p class="text-muted fs-5">We go beyond just delivery to provide a seamless experience.</p>
    </div>

    <div class="row g-4 animate-up">
        <div class="col-md-4">
            <div class="f-card p-5 h-100 shadow-sm text-center">
                <div class="cat-icon mb-4">🚀</div>
                <h3 class="fw-bold mb-3">Ultra Fast Delivery</h3>
                <p class="text-muted">Get your groceries delivered to your doorstep within 60 minutes of ordering.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="f-card p-5 h-100 shadow-sm text-center border-purple">
                <div class="cat-icon mb-4">🛡️</div>
                <h3 class="fw-bold mb-3">Quality Guarantee</h3>
                <p class="text-muted">If you're not happy with the freshness, we'll replace it for free, no questions asked.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="f-card p-5 h-100 shadow-sm text-center">
                <div class="cat-icon mb-4">📱</div>
                <h3 class="fw-bold mb-3">Smart Tracking</h3>
                <p class="text-muted">Monitor your delivery person in real-time with our advanced GPS tracking system.</p>
            </div>
        </div>
    </div>

    <div class="mt-5 p-5 rounded-4 bg-purple-dim text-center animate-up">
        <h2 class="fw-bold text-purple mb-3">Want more?</h2>
        <p class="text-muted mb-4">Subscribe to our **Nexamart Plus** program for unlimited free delivery and exclusive member discounts.</p>
        <button class="gh-btn gh-btn-primary px-5">Join Now</button>
    </div>
</div>
