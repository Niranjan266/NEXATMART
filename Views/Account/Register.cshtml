@model OnlineGroceryShop.Models.User
@{
    ViewData["Title"] = "Join Us";
}

<div class="row justify-content-center pt-5">
    <div class="col-md-5 animate-up">
        <div class="f-card p-5 shadow-sm" style="background: white;">
            <h2 class="text-center fw-bold mb-2">Create Account</h2>
            <p class="text-center text-muted mb-5">Start your fresh journey with Nexamart today.</p>
            
            <form asp-action="Register" method="post">
                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted">Full Name</label>
                    <input asp-for="Name" class="form-control bg-light border-0 py-3 px-4" placeholder="Enter your name" required style="border-radius: 12px; color: var(--f-text);">
                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted">Phone Number</label>
                    <input asp-for="PhoneNumber" type="tel" class="form-control bg-light border-0 py-3 px-4" placeholder="Your phone number" required style="border-radius: 12px; color: var(--f-text);">
                    <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted">Email Address</label>
                    <input asp-for="Email" type="email" class="form-control bg-light border-0 py-3 px-4" placeholder="Your email address" required style="border-radius: 12px; color: var(--f-text);">
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="mb-5">
                    <label class="form-label small fw-bold text-muted">Password</label>
                    <input asp-for="PasswordHash" type="password" class="form-control bg-light border-0 py-3 px-4" placeholder="Create a password" required style="border-radius: 12px; color: var(--f-text);">
                </div>
                <button type="submit" class="gh-btn gh-btn-primary w-100 py-3 shadow-sm">Get Started</button>
            </form>
            
            <div class="mt-5 text-center border-top pt-4">
                <p class="text-muted small">Already have an account? <a asp-action="Login" class="text-purple text-decoration-none fw-bold">Sign In</a></p>
            </div>
        </div>
    </div>
</div>
